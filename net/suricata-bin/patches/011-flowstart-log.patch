Index: suricata-7.0.10/src/output-json-flowstart.c
===================================================================
--- /dev/null
+++ suricata-7.0.10/src/output-json-flowstart.c
@@ -0,0 +1,301 @@
+/* Copyright (C) 2007-2017 Open Information Security Foundation
+ *
